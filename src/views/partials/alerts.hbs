<link rel="stylesheet" href="../css/partials.style.css">

{{#if success}}
<div class="alert alert--success" role="alert">
  <svg class="alert__icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
    <path d="M5.5 8l2 2 3-3" stroke="currentColor" stroke-width="1.3"
          stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
  <div class="alert__body">
    <span class="alert__label">Success</span>
    <p class="alert__msg">{{success}}</p>
  </div>
  <button class="alert__close" aria-label="Dismiss">×</button>
</div>
{{/if}}

{{#if error}}
<div class="alert alert--error" role="alert">
  <svg class="alert__icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
    <path d="M8 5v4M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
  </svg>
  <div class="alert__body">
    <span class="alert__label">Error</span>
    <p class="alert__msg">{{error}}</p>
  </div>
  <button class="alert__close" aria-label="Dismiss">×</button>
</div>
{{/if}}

{{#if warning}}
<div class="alert alert--warning" role="alert">
  <svg class="alert__icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
    <path d="M8 2L14.5 13.5H1.5L8 2z" stroke="currentColor" stroke-width="1.3"
          stroke-linejoin="round"/>
    <path d="M8 6v3.5M8 11.5v.5" stroke="currentColor" stroke-width="1.4"
          stroke-linecap="round"/>
  </svg>
  <div class="alert__body">
    <span class="alert__label">Warning</span>
    <p class="alert__msg">{{warning}}</p>
  </div>
  <button class="alert__close" aria-label="Dismiss">×</button>
</div>
{{/if}}

{{#if message}}
<div class="alert alert--info" role="alert">
  <svg class="alert__icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
    <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
    <path d="M8 7.5V12M8 5v.5" stroke="currentColor" stroke-width="1.4"
          stroke-linecap="round"/>
  </svg>
  <div class="alert__body">
    <span class="alert__label">Info</span>
    <p class="alert__msg">{{message}}</p>
  </div>
  <button class="alert__close" aria-label="Dismiss">×</button>
</div>
{{/if}}

<script src="../js/main.js"></script>