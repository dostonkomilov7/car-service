<link rel="stylesheet" href="../css/forgot-reset.style.css">

<div class="auth-wrapper">
  <div class="auth-card">

    <div class="auth-card__header">
      <a href="/" class="navbar__brand">
        <div class="navbar__logo">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M2 12l1.5-5h11L16 12" stroke="#0e0e0f" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="1" y="12" width="16" height="3" rx="1.5" fill="#0e0e0f"/>
            <circle cx="5" cy="15.5" r="1.5" fill="#0e0e0f"/>
            <circle cx="13" cy="15.5" r="1.5" fill="#0e0e0f"/>
          </svg>
        </div>
        <span>AUTO<span class="accent">PRO</span></span>
      </a>
    </div>

    <div class="auth-card__body">

      {{#if tokenExpired}}
      {{! ── Token muddati o'tgan ── }}
      <div class="auth-heading" style="text-align:center">
        <div class="fp-icon fp-icon--error">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.4"/>
            <path d="M12 7v6M12 15.5v.5"
                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="section-label">Link Expired</div>
        <h1 class="auth-title">Link Expired</h1>
        <p class="auth-subtext">
          This reset link has expired or already been used.
          Request a new one below.
        </p>
      </div>
      <a href="/auth/forgot-password" class="btn btn--primary btn--full"
         style="display:flex;align-items:center;justify-content:center;margin-top:.5rem">
        Request New Link →
      </a>

      {{else}}
      {{! ── Yangi parol formasi ── }}
      <div class="auth-heading" style="text-align:center">
        <div class="fp-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="11" width="18" height="11" rx="2.5"
                  stroke="currentColor" stroke-width="1.4"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"
                  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M10 16l2 2 3-3"
                  stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="section-label">New Password</div>
        <h1 class="auth-title">Reset Password</h1>
        <p class="auth-subtext">
          Choose a strong new password for
          <strong class="auth-subtext__em">{{email}}</strong>
        </p>
      </div>

      {{> alerts}}

      <form action="/api/auth/reset-password?userId={{userId}}" method="POST"
            class="auth-form" id="resetForm">

        <div class="field">
          <label for="password">New Password</label>
          <div class="input-eye">
            <input type="password" id="password" name="password"
                   placeholder="Min. 8 characters"
                   required minlength="8" autocomplete="new-password">
            <button type="button" class="input-eye__btn"
                    data-target="password" aria-label="Toggle password">
              <svg class="eye-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <ellipse cx="8" cy="8" rx="6.5" ry="4" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="8" cy="8" r="2" fill="currentColor"/>
              </svg>
            </button>
          </div>

          {{! Strength bar }}
          <div class="strength-bar" id="strengthBar">
            <div class="strength-bar__track">
              <div class="strength-bar__seg" id="seg1"></div>
              <div class="strength-bar__seg" id="seg2"></div>
              <div class="strength-bar__seg" id="seg3"></div>
              <div class="strength-bar__seg" id="seg4"></div>
            </div>
            <span class="strength-bar__label" id="strengthLabel"></span>
          </div>
        </div>

        <div class="field">
          <label for="confirmPassword">Confirm Password</label>
          <div class="input-eye">
            <input type="password" id="confirmPassword" name="confirmPassword"
                   placeholder="Repeat password"
                   required autocomplete="new-password">
            <button type="button" class="input-eye__btn"
                    data-target="confirmPassword" aria-label="Toggle password">
              <svg class="eye-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <ellipse cx="8" cy="8" rx="6.5" ry="4" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="8" cy="8" r="2" fill="currentColor"/>
              </svg>
            </button>
            <span class="input-eye__check" id="matchCheck" hidden>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 7l3 3 5-5" stroke="#639922"
                      stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
          <p class="field__hint field__hint--error" id="matchError" hidden>
            Passwords do not match.
          </p>
        </div>

        {{! Requirements checklist }}
        <div class="pw-rules" id="pwRules">
          <div class="pw-rule" id="rule-len">
            <svg class="pw-rule__icon" width="13" height="13" viewBox="0 0 13 13" fill="none">
              <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            At least 8 characters
          </div>
          <div class="pw-rule" id="rule-upper">
            <svg class="pw-rule__icon" width="13" height="13" viewBox="0 0 13 13" fill="none">
              <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            One uppercase letter
          </div>
          <div class="pw-rule" id="rule-num">
            <svg class="pw-rule__icon" width="13" height="13" viewBox="0 0 13 13" fill="none">
              <circle cx="6.5" cy="6.5" r="5" stroke="currentColor" stroke-width="1.2"/>
            </svg>
            One number or symbol
          </div>
        </div>

        <button type="submit" class="btn btn--primary btn--full" style="margin-top:4px">
          Set New Password →
        </button>

      </form>
      {{/if}}

      <p class="auth-switch">
        Back to <a href="/login">Sign in →</a>
      </p>

    </div>
  </div>
</div>

<script src="../js/reset.js"></script>