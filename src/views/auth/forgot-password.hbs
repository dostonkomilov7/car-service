<link rel="stylesheet" href="../css/forgot-reset.style.css">
<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-card__header">
            <a href="/" class="navbar__brand">
                <div class="navbar__logo">
                    <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
                        <path d="M2 12l1.5-5h11L16 12" stroke="#0e0e0f" stroke-width="1.5" stroke-linecap="round" />
                        <rect x="1" y="12" width="16" height="3" rx="1.5" fill="#0e0e0f" />
                        <circle cx="5" cy="15.5" r="1.5" fill="#0e0e0f" />
                        <circle cx="13" cy="15.5" r="1.5" fill="#0e0e0f" />
                    </svg>
                </div>
                <span>AUTO<span class="accent">PRO</span></span>
            </a>
        </div>

        <div class="auth-card__body">

            {{#if email}}
            <div class="auth-heading" style="text-align:center">
                <div class="fp-icon fp-icon--success">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M3 10l5 5L17 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                            stroke-linejoin="round" />
                    </svg>
                </div>
                <div class="section-label">Email Sent</div>
                <h1 class="auth-title">Check Your Inbox</h1>
                <p class="auth-subtext">
                    We sent a reset link to
                    <strong class="auth-subtext__em">{{email}}</strong>.
                    The link expires in <strong class="auth-subtext__em">30 minutes</strong>.
                </p>
            </div>

            <div class="fp-sent-box">
                <div class="fp-sent-box__steps">
                    <div class="fp-step">
                        <span class="fp-step__num">1</span>
                        <span>Open your email inbox</span>
                    </div>
                    <div class="fp-step">
                        <span class="fp-step__num">2</span>
                        <span>Click the reset link in the email</span>
                    </div>
                    <div class="fp-step">
                        <span class="fp-step__num">3</span>
                        <span>Choose a new password</span>
                    </div>
                </div>
            </div>

            <form action="/api/auth/forgot-password" method="POST" class="auth-form">
                <input type="hidden" name="email" value="{{email}}">
                <button type="submit" class="btn btn--ghost btn--full">
                    Resend Email
                </button>
            </form>

            {{else}}
            {{! ── Email kiritish formasi ── }}
            <div class="auth-heading" style="text-align:center">
                <div class="fp-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <rect x="3" y="11" width="18" height="11" rx="2.5" stroke="currentColor" stroke-width="1.4" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.4"
                            stroke-linecap="round" />
                        <circle cx="12" cy="16" r="1.5" fill="currentColor" />
                    </svg>
                </div>
                <div class="section-label">Account Recovery</div>
                <h1 class="auth-title">Forgot Password?</h1>
                <p class="auth-subtext">
                    No worries. Enter your email and we'll send a reset link right away.
                </p>
            </div>

            {{> alerts}}

            <form action="/api/auth/forgot-password" method="POST" class="auth-form">

                <div class="field">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" placeholder="you@example.com" required
                        autocomplete="email">
                </div>

                <button type="submit" class="btn btn--primary btn--full" style="margin-top:4px">
                    Send Reset Link →
                </button>

            </form>

            <p class="auth-switch">
                Remember it? <a href="/login">Sign in →</a>
            </p>
            {{/if}}
        </div>
    </div>
</div>