<link rel="stylesheet" href="../css/partials.style.css">

<footer class="footer">
  <div class="footer__grid">

    <div class="footer__col footer__col--brand">
      <a href="/" class="footer__brand">
        <div class="navbar__logo">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M2 12l1.5-5h11L16 12" stroke="#0e0e0f" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="1" y="12" width="16" height="3" rx="1.5" fill="#0e0e0f"/>
            <circle cx="5" cy="15.5" r="1.5" fill="#0e0e0f"/>
            <circle cx="13" cy="15.5" r="1.5" fill="#0e0e0f"/>
          </svg>
        </div>
        <span>AUTO<span class="accent">PRO</span></span>
      </a>
      <p class="footer__tagline">Professional car care you can count on. Certified mechanics, transparent pricing, same-day service.</p>
      <div class="footer__social">
        <a href="#" class="footer__social-btn" aria-label="Facebook">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="1" width="12" height="12" rx="3" stroke="currentColor" stroke-width="1.2"/>
            <path d="M6 13V7H4.5V5.5H6V4.5C6 3.4 6.7 3 7.5 3H9v1.5H8C7.7 4.5 7.5 4.7 7.5 5v.5H9L8.7 7H7.5v6H6z" fill="currentColor"/>
          </svg>
        </a>
        <a href="#" class="footer__social-btn" aria-label="Instagram">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <rect x="1" y="1" width="12" height="12" rx="3" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="7" cy="7" r="2.5" stroke="currentColor" stroke-width="1.2"/>
            <circle cx="10.5" cy="3.5" r="0.75" fill="currentColor"/>
          </svg>
        </a>
        <a href="#" class="footer__social-btn" aria-label="Twitter / X">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M2 2l10 10M12 2L2 12" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Services</h4>
      <ul class="footer__list">
        <li><a href="/booking?service=oil-change">Oil Change</a></li>
        <li><a href="/booking?service=brakes">Brake Repair</a></li>
        <li><a href="/booking?service=tyre">Tyre Service</a></li>
        <li><a href="/booking?service=diagnostics">Engine Diagnostics</a></li>
        <li><a href="/booking?service=ac">AC Service</a></li>
        <li><a href="/booking?service=full">Full Service</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Company</h4>
      <ul class="footer__list">
        <li><a href="/api">Home</a></li>
        <li><a href="/api/my-bookings">My Bookings</a></li>
        <li><a href="api/create">Book a Service</a></li>
        <li><a href="#contact">Contact</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms of Service</a></li>
      </ul>
    </div>

    <div class="footer__col">
      <h4 class="footer__heading">Hours</h4>
      <ul class="footer__hours">
        <li><span>Mon – Fri</span><strong>8am – 6pm</strong></li>
        <li><span>Saturday</span><strong>9am – 4pm</strong></li>
        <li><span>Sunday</span><strong>Closed</strong></li>
      </ul>
      <div class="footer__phone">
        <div class="footer__phone-label">Call us</div>
        <div class="footer__phone-num">+998 - 7777 - 1 - 7777</div>
      </div>
    </div>

  </div>

  <div class="footer__bottom">
    <p>© {{year}} AutoPro. All rights reserved.</p>
    <div class="footer__bottom-links">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/sitemap">Sitemap</a>
    </div>
  </div>
</footer>