<link rel="stylesheet" href="../css/auth.style.css">
{{> alerts}}
<div class="auth-wrapper">
  <div class="auth-card">

    <div class="auth-card__header">
      <a href="/" class="navbar__brand">
        <div class="navbar__logo">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <path d="M2 12l1.5-5h11L16 12" stroke="#0e0e0f" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="1" y="12" width="16" height="3" rx="1.5" fill="#0e0e0f"/>
            <circle cx="5" cy="15.5" r="1.5" fill="#0e0e0f"/>
            <circle cx="13" cy="15.5" r="1.5" fill="#0e0e0f"/>
          </svg>
        </div>
        <span>AUTO<span class="accent">PRO</span></span>
      </a>
    </div>

    <div class="auth-card__body">

      <div class="auth-heading">
        <div class="section-label">Welcome Back</div>
        <h1 class="auth-title">Sign In</h1>
      </div>

      {{> alerts}}

      <form action="/api/auth/login" method="POST" class="auth-form">

        <div class="field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email"
                 placeholder="you@example.com"
                 value="{{email}}" required autocomplete="email">
        </div>

        <div class="field">
          <div class="field__label-row">
            <label for="password">Password</label>
            <a href="/auth/forgot-password" class="field__link">Forgot password?</a>
          </div>
          <input type="password" id="password" name="password"
                 placeholder="••••••••" required autocomplete="current-password">
        </div>

        <div class="auth-form__check">
          <input type="checkbox" id="remember" name="remember" value="1">
          <label for="remember">Remember me</label>
        </div>

        <button type="submit" class="btn btn--primary btn--full">Sign In →</button>

      </form>

      <p class="auth-switch">
        Don't have an account? <a href="/api/register">Create one →</a>
      </p>

    </div>
  </div>
</div>